DB_HOST=localhost        # alamat server DB
                         # local → localhost
                         # VPS   → IP VPS kalian, misal 103.xxx.xxx.xxx
DB_PORT=5432             # port default PostgreSQL, biasanya tidak perlu diubah
DB_NAME=internal_app     # nama database yang kalian buat
                         # bebas, misal: myapp_db, perusahaan_internal
DB_USER=app              # username PostgreSQL
DB_PASSWORD=app          # password PostgreSQL
# Ini gabungan dari semua di atas, format sudah ditentukan
# Tinggal sesuaikan dengan nilai di atas
DATABASE_URL="postgresql://app:app@localhost:5432/internal_app"
#                          user:pass@host  :port/nama_db
JWT_SECRET="dev-only-change-me-min-32-characters-long!!"
# Ini kunci rahasia untuk sign token JWT
# Development → boleh string apapun asal panjang (min 32 karakter)
# Production  → WAJIB ganti dengan string random yang kuat

# Cara generate JWT_SECRET yang aman:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Output contoh: a3f8c2d1e4b5a6f7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1

PORT=3000          # port NestJS berjalan
                   # akses via http://localhost:3000
NODE_ENV=development   # development / production
                       # mempengaruhi banyak behaviour (log, seed, dll)
SEED_MODE=demo         # demo    → isi data dummy lengkap (local)
                       # minimal → hanya data baseline (production)
ALLOW_DEMO_SEED=false  # safety guard agar seed demo tidak jalan di production
                       # local → boleh true
                       # production → tetap false
REDIS_HOST=127.0.0.1   # sama seperti DB_HOST
                        # local      → 127.0.0.1 atau localhost
                        # VPS/Docker → sesuaikan
REDIS_PORT=6379         # port default Redis, biasanya tidak perlu diubah
# REDIS_PASSWORD=       # kosong = Redis tanpa password (oke untuk local)
                        # production → sebaiknya set password
                        # REDIS_PASSWORD=passwordkuat123

# Daftar origin FE yang boleh akses BE
# Pisah dengan koma kalau lebih dari 1

CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# 3000 → misal FE Next.js
# 5173 → misal FE Vite/React

# Kalau FE sudah deploy ke domain:
# CORS_ORIGIN=https://app.perusahaan.com

# ❌ Jangan pakai * di production
# CORS_ORIGIN=*

THROTTLE_TTL_MS=60000    # window waktu dalam milidetik
                          # 60000 = 60 detik = 1 menit
THROTTLE_LIMIT=120        # max request per IP dalam window tersebut
                          # artinya: 1 IP boleh max 120 request per menit